# Minimal Insightful test VM profile
# This is a planning/config template for creating a real VM in UTM.
# It is not used by docker-compose.

VM_NAME=insightful-test-ubuntu-01
VM_HOSTNAME=insightful-test-ubuntu-01
VM_OS=Ubuntu Desktop LTS
VM_ARCH=arm64          # Apple Silicon native. Use amd64 only if your Insightful agent requires it.
VM_CPU=2
VM_MEMORY_GB=4
VM_DISK_GB=32
VM_DISPLAY=1280x720
VM_NETWORK=shared-nat

# Optional: install Tailscale inside the VM if you need to reach the VM directly.
INSTALL_TAILSCALE=false

# Insightful should be installed from the org-admin-provided installer/invite only.
INSIGHTFUL_INSTALLER_SOURCE=admin-provided
INSIGHTFUL_TEST_USER=insightful-test-user@example.com
