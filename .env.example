# ─────────────────────────────────────────────────────────────────────────────
# neko-remote configuration — copy to `.env` and edit.  `make setup` does this.
# All values have sane defaults in docker-compose.yml; override only what you need.
# ─────────────────────────────────────────────────────────────────────────────

# ── Browser image ────────────────────────────────────────────────────────────
# Use the GHCR V3 images (native arm64, no emulation). Swap the app to change
# browser: chromium | firefox | brave | vivaldi | google-chrome | ungoogled-chromium
NEKO_IMAGE=ghcr.io/m1k1o/neko/chromium:latest

# ── Credentials ──────────────────────────────────────────────────────────────
# Admin controls the browser. Only ONE person should use the admin login.
ADMIN_USER=collab
ADMIN_PASSWORD=change-me-admin

# Viewers can only watch (never control), hand this out freely.
VIEWER_USER=viewer
VIEWER_PASSWORD=change-me-viewer

# ── Display ──────────────────────────────────────────────────────────────────
# WxH@FPS
NEKO_SCREEN=1920x1080@30

# ── Ports ────────────────────────────────────────────────────────────────────
HTTP_PORT=8080      # web UI
MUX_PORT=52000      # single WebRTC media port (UDP + TCP)

# ── Container ────────────────────────────────────────────────────────────────
SHM_SIZE=2gb        # shared memory for the browser (raise for heavy pages)

# ── Tailscale ────────────────────────────────────────────────────────────────
# Auto-filled by `make setup` / `make ip`. Your machine's Tailscale IPv4.
# Get it with: tailscale ip -4
TAILSCALE_IP=
