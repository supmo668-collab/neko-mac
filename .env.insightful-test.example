# Optional Insightful test desktop config
# Copy to .env.insightful-test and edit locally. Do not commit the real file.

# Web desktop image. LinuxServer Webtop is multi-arch and responsive on Apple Silicon.
INSIGHTFUL_DESKTOP_IMAGE=lscr.io/linuxserver/webtop:ubuntu-mate
# Use linux/arm64 for native Apple Silicon. Use linux/amd64 for x86_64 installers
# such as Workpuls.AppImage / older Insightful builds.
INSIGHTFUL_PLATFORM=linux/arm64
INSIGHTFUL_CONTAINER_NAME=insightful-test-desktop
INSIGHTFUL_HOSTNAME=insightful-test-workvm-01
INSIGHTFUL_DESKTOP_TITLE=Insightful Test Desktop

# Browser desktop access ports on the Mac host.
# HTTP stays localhost-only because the app requires HTTPS for remote use.
INSIGHTFUL_HTTP_BIND_IP=127.0.0.1
# Set by init to your Tailscale IPv4. HTTPS stays private to Tailnet.
INSIGHTFUL_HTTPS_BIND_IP=
INSIGHTFUL_HTTP_PORT=3010
INSIGHTFUL_HTTPS_PORT=3011

# Login for the web desktop UI. Change before exposing beyond localhost/Tailnet.
INSIGHTFUL_UI_USER=tester
INSIGHTFUL_UI_PASSWORD=change-me-desktop

# Persistence and installer drop paths, relative to this repo.
INSIGHTFUL_CONFIG_DIR=./insightful-test/config
INSIGHTFUL_INSTALLER_DIR=./insightful-test/installers
INSIGHTFUL_SHARED_DIR=./insightful-test/shared

# Container user mapping. On macOS this is mostly for file ownership consistency.
PUID=1000
PGID=1000
TZ=Etc/UTC

# Desktop container resources.
INSIGHTFUL_SHM_SIZE=2gb
